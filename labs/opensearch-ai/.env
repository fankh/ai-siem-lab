# 스택 버전/모델 설정 — docker compose 와 setup.sh 가 함께 사용
# Docker Hub에서 현재 태그 확인 후 조정: opensearchproject/opensearch
OPENSEARCH_VERSION=2.19.0

# Ollama 모델. RAM 여유에 따라 선택:
#   llama3.1:8b   (~5GB VRAM/RAM, 권장)
#   llama3.2:3b   (~3GB, 저사양 실습용)
#   qwen2.5:7b    (코드/로그 분석 우수)
OLLAMA_MODEL=llama3.1:8b

# OpenSearch JVM 힙 (호스트 RAM의 ~50%, 최대 32g 미만)
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
