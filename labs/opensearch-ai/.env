# 스택 버전/모델 설정 — docker compose 와 setup.sh 가 함께 사용
# Docker Hub에서 현재 태그 확인 후 조정: opensearchproject/opensearch
OPENSEARCH_VERSION=2.19.0

# Ollama 모델 — 하드웨어(특히 RAM)에 맞춰 선택.
# 소형 모델도 "힌트 프롬프트 + temperature=0"이면 한국어 트리아지가 안정적으로 동작함(가이드/매뉴얼 참고).
#   qwen2.5:1.5b  (~1GB)  초저사양 — 한국어·분류 양호(본 랩 검증)
#   qwen2.5:3b    (~2GB)  저사양 표준 — 권장(한국어·지시이행 우수, 본 랩 검증)
#   qwen2.5:7b    (~5GB)  중사양 — 분석 품질↑
#   llama3.1:8b   (~5GB)  고사양 — 범용 품질↑
# ⚠️ llama3.2:3b 는 같은 크기여도 한국어 출력이 불안정(외국어 토큰 혼입·간단 분류 오답)하여 비권장.
OLLAMA_MODEL=qwen2.5:3b

# OpenSearch JVM 힙 — 호스트 RAM 의 일부. RAM 8GB(모델과 분담) 기준 1g 권장.
# 매우 빠듯하면(≤6GB) 512m 로: OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
